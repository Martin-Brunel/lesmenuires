DATABASE_URL=postgres://lesmenuires:lesmenuires@localhost:5544/lesmenuires
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,sqlx=warn

# Origine autorisée pour le front (CORS credentialé).
FRONT_ORIGIN=http://localhost:3000

# Dossier de stockage des photos uploadées (servies sur /media).
MEDIA_DIR=./media

# Paiement. Sans STRIPE_SECRET_KEY, le provider 'mock' simule tout le flux.
# Renseigner ces clés (mode test) activera Stripe (provider à brancher).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Admin seedé au premier démarrage si la table admin_user est vide.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
