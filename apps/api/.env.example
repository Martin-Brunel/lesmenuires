# =============================================================================
# API (Rust/Axum) — configuration
# Copier en `.env` puis renseigner. NE JAMAIS committer le .env réel.
# =============================================================================

# --- Base de données -------------------------------------------------------
# En local : Postgres du docker-compose (port 5544).
# En prod (compose) : host = nom du service `postgres`, port interne 5432.
DATABASE_URL=postgres://lesmenuires:lesmenuires@localhost:5544/lesmenuires

# --- Serveur ---------------------------------------------------------------
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,sqlx=warn

# URL publique de l'API (liens dans les e-mails : magic link, etc.).
# Prod : https://votre-domaine.fr
API_BASE_URL=http://localhost:8080

# Origine autorisée pour le front (CORS credentialé — pas de wildcard possible).
# Prod : https://votre-domaine.fr
FRONT_ORIGIN=http://localhost:3000

# Poser à `true` en production (HTTPS) : ajoute le flag Secure aux cookies de session.
COOKIE_SECURE=false

# Contexte d'exécution. `production` = signal explicite qui, combiné à un provider
# de paiement `mock` (STRIPE_SECRET_KEY absente), fait REFUSER le démarrage — garde-
# fou anti « réservations confirmées sans paiement réel ». COOKIE_SECURE=true fait
# aussi office de signal prod. Laisser vide en dev.
# APP_ENV=production

# --- Stockage photos -------------------------------------------------------
# Dossier disque des photos uploadées (servies sur /media). En prod : volume monté.
MEDIA_DIR=./media

# --- Admin back-office -----------------------------------------------------
# Compte admin seedé au premier démarrage si la table admin_user est vide.
# CHANGER en production (mot de passe fort).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Paiement (Stripe) -----------------------------------------------------
# Sans STRIPE_SECRET_KEY, le provider `mock` simule tout le flux (dev/CI).
# Renseigner active Stripe (test : sk_test_/pk_test_, prod : sk_live_/pk_live_).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Signature des webhooks (obtenu via `stripe listen` ou le dashboard).
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- E-mail (Resend) -------------------------------------------------------
# Sans RESEND_API_KEY : e-mails désactivés (no-op + log).
# RESEND_API_KEY=re_...
# Expéditeur : un domaine vérifié sur resend.com/domains en production.
MAIL_FROM=onboarding@resend.dev

# --- Planificateur ---------------------------------------------------------
# Intervalle du worker de fond (prélèvement du solde J-14, pré-notification,
# relances panier, expiration paniers, purge jetons). En secondes.
SCHEDULER_INTERVAL_SECS=300
