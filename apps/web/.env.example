# =============================================================================
# Web (Next.js) — configuration
# Copier en `.env.local` (dev) ou fournir via l'environnement (prod).
# =============================================================================

# URL de base de l'API Rust (apps/api). Utilisée côté serveur (SSR du booking
# context) ET côté client (création de réservation) → préfixe NEXT_PUBLIC_.
# Prod : https://votre-domaine.fr (le reverse-proxy route /api vers l'API).
NEXT_PUBLIC_API_URL=http://localhost:8080
