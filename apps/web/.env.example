# =============================================================================
# Web (Next.js) — configuration
# Copier en `.env.local` (dev) ou fournir via l'environnement (prod).
# =============================================================================

# URL de base de l'API Rust (apps/api). Utilisée côté serveur (SSR du booking
# context) ET côté client (création de réservation) → préfixe NEXT_PUBLIC_.
# Prod : https://votre-domaine.fr (le reverse-proxy route /api vers l'API).
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL publique du site (métadonnées SEO, sitemap.xml, robots.txt). Optionnel :
# par défaut = NEXT_PUBLIC_API_URL (front et API partagent le domaine en prod).
# À renseigner seulement si les domaines front/API divergent.
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr

# --- Identité légale (affichée sur /mentions-legales, /cgv, /confidentialite) ---
# À COMPLÉTER par le loueur avant mise en ligne (inliné au build → reconstruire
# l'image web après modification). Données obligatoires : éditeur + hébergeur.
NEXT_PUBLIC_LOCATION=Les Ménuires
NEXT_PUBLIC_CONTACT_EMAIL=contact@votre-domaine.fr
NEXT_PUBLIC_EDITOR_NAME=
NEXT_PUBLIC_EDITOR_STATUS=Loueur en meublé non professionnel (LMNP)
NEXT_PUBLIC_EDITOR_ADDRESS=
NEXT_PUBLIC_EDITOR_SIRET=
NEXT_PUBLIC_EDITOR_PHONE=
NEXT_PUBLIC_HOST_NAME=
NEXT_PUBLIC_HOST_ADDRESS=
NEXT_PUBLIC_MEDIATOR_NAME=
NEXT_PUBLIC_MEDIATOR_ADDRESS=
NEXT_PUBLIC_MEDIATOR_WEBSITE=
NEXT_PUBLIC_LEGAL_DATE=2026-07-13

# Mesure d'audience Umami self-hosted (optionnelle — voir docs/DEPLOY.md
# « Mesure d'audience »). Vide = aucun script injecté.
NEXT_PUBLIC_ANALYTICS_SRC=
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=
