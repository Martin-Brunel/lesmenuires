# =============================================================================
# Déploiement (docker-compose.prod.yml) — variables d'orchestration
# Copier en `.env` à la racine puis renseigner. Utilisé par le compose de prod.
# =============================================================================

# Domaine public servi par Caddy (TLS automatique Let's Encrypt).
DOMAIN=votre-domaine.fr
# E-mail pour les certificats Let's Encrypt.
ACME_EMAIL=admin@votre-domaine.fr

# --- Base de données -------------------------------------------------------
POSTGRES_USER=lesmenuires
POSTGRES_PASSWORD=changez-moi-en-prod
POSTGRES_DB=lesmenuires

# --- Admin back-office (seed au 1er démarrage) -----------------------------
ADMIN_EMAIL=admin@votre-domaine.fr
ADMIN_PASSWORD=changez-moi-mot-de-passe-fort

# --- Stripe (mode live en production) --------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- E-mail (Resend) -------------------------------------------------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# Domaine vérifié sur resend.com/domains.
MAIL_FROM=reservation@votre-domaine.fr

# --- Front (inliné au build de l'image web) ---------------------------------
# Nom du site affiché sur le front (le back-office et les e-mails utilisent le
# nom de la propriété en base).
NEXT_PUBLIC_SITE_NAME="L'Adret"
NEXT_PUBLIC_LOCATION="Les Ménuires"
NEXT_PUBLIC_CONTACT_EMAIL=contact@votre-domaine.fr
NEXT_PUBLIC_EDITOR_NAME=
NEXT_PUBLIC_EDITOR_STATUS="Loueur en meublé non professionnel (LMNP)"
NEXT_PUBLIC_EDITOR_ADDRESS=
NEXT_PUBLIC_EDITOR_SIRET=
NEXT_PUBLIC_EDITOR_PHONE=
NEXT_PUBLIC_HOST_NAME=
NEXT_PUBLIC_HOST_ADDRESS=
NEXT_PUBLIC_MEDIATOR_NAME=
NEXT_PUBLIC_MEDIATOR_ADDRESS=
NEXT_PUBLIC_MEDIATOR_WEBSITE=
NEXT_PUBLIC_LEGAL_DATE=2026-07-13

# --- Divers ----------------------------------------------------------------
RUST_LOG=info,sqlx=warn
SCHEDULER_INTERVAL_SECS=300

# --- Sauvegardes automatiques (service backup) -----------------------------
BACKUP_INTERVAL_SECS=86400
BACKUP_RETENTION_DAYS=14
